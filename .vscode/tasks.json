{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run JSP Server",
      "type": "shell",
      "command": "./gradlew",
      "args": [
        "run"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "group": "build"
    }
  ]
}
